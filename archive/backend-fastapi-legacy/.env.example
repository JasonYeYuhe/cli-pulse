# CLI Pulse Backend Configuration
# Copy this file to .env and fill in the values.

# Database path (SQLite, used by local backend)
CLI_PULSE_DB_PATH=backend/data/cli_pulse.db

# Supabase credentials (used by helper and production backend)
CLI_PULSE_SUPABASE_URL=https://your-project.supabase.co
CLI_PULSE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: custom cost configuration (JSON)
# CLI_PULSE_COST_CONFIG_JSON={"codex": {"rate_per_1k_usage": 0.012, "status": "Estimated"}}
